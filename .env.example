# Server
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/airbnb_alerts
# Optional read replica (Railway)
DATABASE_REPLICA_URL=postgresql://user:password@localhost:5432/airbnb_alerts_replica
# Or use Railway's auto-injected DATABASE_URL
# Set to 'false' only if your provider uses a self-signed cert (e.g. Railway private networking)
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# External logical replication (Supabase -> Railway)
# IMPORTANT: use Supabase DIRECT connection string here (not pooler).
SUPABASE_DIRECT_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres
# Optional explicit override for replication source; defaults to SUPABASE_DIRECT_URL then DATABASE_URL.
DATABASE_REPLICATION_SOURCE_URL=
REPLICATION_PUBLICATION=airbnb_alerts_pub
REPLICATION_SUBSCRIPTION=airbnb_alerts_sub
REPLICATION_SLOT=airbnb_alerts_slot
# Optional comma-separated list, e.g. "public.users,public.search_alerts". Empty = FOR ALL TABLES.
REPLICATION_TABLES=
# Whether to copy existing data when creating subscription.
REPLICATION_COPY_DATA=true

# Supabase Auth (required to trigger Dreamlit supabase.auth.* workflows)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_publishable_key
SUPABASE_SECRET_KEY=sb_secret_your_secret_key
# Backward-compatible old key names (optional; only if your project still uses them)
# SUPABASE_ANON_KEY=your-supabase-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Redis (for Bull queue)
REDIS_URL=redis://localhost:6379
# Or use Railway's auto-injected REDIS_URL

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin dashboard credentials
ADMIN_JWT_SECRET=your-admin-jwt-secret-change-this
# Preferred: allowlisted app users can elevate to admin from existing login cookie.
ADMIN_ALLOWED_EMAILS=admin1@example.com,admin2@example.com

# Google OAuth (https://console.cloud.google.com/ → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (for notifications)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=Alert Buzz <noreply@alertbuzz.com>

# Python scraper path
PYTHON_PATH=python3

# Proxy (optional - for avoiding Airbnb blocks)
PROXY_URL=

# Scraping settings
SCRAPE_INTERVAL_BASIC=86400000
SCRAPE_INTERVAL_PREMIUM=900000
MAX_RESULTS_PER_SEARCH=200

# Railway volume path (if using volume for temp files)
TEMP_DIR=/tmp

# Feature flags
# iCal checks currently fail for many Airbnb listings (HTTP 400). Keep disabled unless you explicitly need it.
ENABLE_ICAL_MONITORING=false
ENABLE_PRICE_TRACKING=true

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create these in your Stripe dashboard
# Dashboard → Products → Add product → Add price
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_YEARLY=price_...

# PostHog (product analytics)
# Get project API key from PostHog project settings.
POSTHOG_PUBLIC_KEY=phc_TOKhCMXcbb3oDR6tKPF074LtBAgBRSCyQbSHMsOaQ9P
# US: https://us.i.posthog.com | EU: https://eu.i.posthog.com
POSTHOG_HOST=https://us.i.posthog.com
# Optional PostHog app links for Admin Dashboard Product Analytics tab
# Example: https://us.posthog.com/project/12345
POSTHOG_APP_HOST=https://us.i.posthog.com/project/322594
POSTHOG_SIGNUP_FUNNEL_URL=https://us.posthog.com/project/322594/insights/new?q=%7B%22kind%22%3A%22InsightVizNode%22%2C%22source%22%3A%7B%22filterTestAccounts%22%3Afalse%2C%22properties%22%3A%5B%5D%2C%22kind%22%3A%22FunnelsQuery%22%2C%22series%22%3A%5B%7B%22custom_name%22%3A%22Signup%20Started%22%2C%22kind%22%3A%22EventsNode%22%2C%22event%22%3A%22auth_signup_started%22%7D%2C%7B%22custom_name%22%3A%22Signup%20Completed%22%2C%22kind%22%3A%22EventsNode%22%2C%22event%22%3A%22auth_signup_completed%22%7D%2C%7B%22custom_name%22%3A%22Email%20Confirmed%22%2C%22kind%22%3A%22EventsNode%22%2C%22event%22%3A%22auth_signup_email_confirmed%22%7D%2C%7B%22custom_name%22%3A%22Login%20Completed%22%2C%22kind%22%3A%22EventsNode%22%2C%22event%22%3A%22auth_login_completed%22%7D%5D%2C%22funnelsFilter%22%3A%7B%22funnelWindowInterval%22%3A7%2C%22funnelWindowIntervalUnit%22%3A%22day%22%7D%7D%7D
