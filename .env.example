POSTHOG_ALERT_CREATION_INSIGHT_URL=https://us.posthog.com/project/322594/insights/new?q=%7B%22kind%22%3A%22InsightVizNode%22%2C%22source%22%3A%7B%22filterTestAccounts%22%3Afalse%2C%22properties%22%3A%5B%5D%2C%22kind%22%3A%22TrendsQuery%22%2C%22interval%22%3A%22day%22%2C%22series%22%3A%5B%7B%22custom_name%22%3A%22Alerts%20Created%22%2C%22math%22%3A%22total%22%2C%22kind%22%3A%22EventsNode%22%2C%22event%22%3A%22alert_created%22%7D%2C%7B%22custom_name%22%3A%22Search%20View%20Clicked%22%2C%22math%22%3A%22total%22%2C%22kind%22%3A%22EventsNode%22%2C%22event%22%3A%22alert_search_view_clicked%22%7D%5D%2C%22breakdownFilter%22%3A%7B%22breakdown_type%22%3A%22event%22%2C%22breakdown%22%3A%22is_free_trial%22%7D%7D%7D
POSTHOG_NOTIFICATION_CTR_INSIGHT_URL=https://us.posthog.com/project/322594/insights/new?q=%7B%22kind%22%3A%22InsightVizNode%22%2C%22source%22%3A%7B%22filterTestAccounts%22%3Afalse%2C%22properties%22%3A%5B%5D%2C%22kind%22%3A%22FunnelsQuery%22%2C%22series%22%3A%5B%7B%22custom_name%22%3A%22Notifications%20Loaded%22%2C%22kind%22%3A%22EventsNode%22%2C%22event%22%3A%22notifications_loaded%22%7D%2C%7B%22custom_name%22%3A%22Notification%20Clicked%22%2C%22kind%22%3A%22EventsNode%22%2C%22event%22%3A%22notification_open_airbnb_clicked%22%7D%5D%2C%22funnelsFilter%22%3A%7B%22funnelWindowInterval%22%3A24%2C%22funnelWindowIntervalUnit%22%3A%22hour%22%7D%2C%22breakdownFilter%22%3A%7B%22breakdown_type%22%3A%22event%22%2C%22breakdown%22%3A%22source%22%7D%7D%7D
